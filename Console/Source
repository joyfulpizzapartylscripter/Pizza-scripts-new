local function getUSTime()
	return os.date("US timeline - %H:%M:%S", os.time() - (60*60*13))
end

local function getLocalTime()
	return os.date("%Z timeline - %H:%M:%S")
end

local highlights = {}
local healthTags = {}

local function highlightPlayers(showHealth)
	for _, plr in pairs(game.Players:GetPlayers()) do
		if plr ~= player and plr.Character then
			local h = Instance.new("Highlight")
			h.FillColor = Color3.new(1,0,0)
			h.Parent = plr.Character
			table.insert(highlights, h)
			if showHealth then
				local bill = Instance.new("BillboardGui", plr.Character)
				bill.Size = UDim2.new(0,100,0,40)
				bill.AlwaysOnTop = true
				local txt = Instance.new("TextLabel", bill)
				txt.Size = UDim2.new(1,0,1,0)
				txt.BackgroundTransparency = 1
				txt.TextColor3 = Color3.new(1,0,0)
				txt.Font = Enum.Font.Code
				txt.Text = "HP: "..plr.Character:FindFirstChild("Humanoid").Health
				table.insert(healthTags, bill)
			end
		end
	end
end

local function clearHighlights()
	for _, h in pairs(highlights) do h:Destroy() end
	for _, h in pairs(healthTags) do h:Destroy() end
	highlights = {}
	healthTags = {}
end

local airjump = false
game:GetService("UserInputService").JumpRequest:Connect(function()
	if airjump then
		humanoid:ChangeState("Jumping")
	end
end)

local noclip = false
game:GetService("RunService").Stepped:Connect(function()
	if noclip and char then
		for _, v in pairs(char:GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide = false
			end
		end
	end
end)

local predicting = false
local predictionLines = {}

local function createLine(fromPos, toPos)
	local part = Instance.new("Part")
	part.Anchored = true
	part.CanCollide = false
	part.Size = Vector3.new(0.1,0.1,(fromPos - toPos).Magnitude)
	part.CFrame = CFrame.lookAt(fromPos, toPos) * CFrame.new(0,0,-part.Size.Z/2)
	part.Color = Color3.new(0,1,0)
	part.Parent = workspace
	return part
end

local function startPrediction()
	predicting = true
	task.spawn(function()
		while predicting do
			for _, plr in pairs(game.Players:GetPlayers()) do
				if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
					local root = plr.Character.HumanoidRootPart
					local futurePos = root.Position + root.Velocity * 1
					local line = createLine(root.Position, futurePos)
					table.insert(predictionLines, line)
					task.delay(0.5, function()
						if line then line:Destroy() end
					end)
				end
			end
			task.wait(0.5)
		end
	end)
end

local function stopPrediction()
	predicting = false
	for _, l in pairs(predictionLines) do
		if l then l:Destroy() end
	end
	predictionLines = {}
end

local draggingEnabled = false
local dragging = false
local dragInput, dragStart, startPos

frame.InputBegan:Connect(function(inputObj)
	if draggingEnabled and inputObj.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = inputObj.Position
		startPos = frame.Position
		inputObj.Changed:Connect(function()
			if inputObj.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

frame.InputChanged:Connect(function(inputObj)
	if inputObj.UserInputType == Enum.UserInputType.MouseMovement then
		dragInput = inputObj
	end
end)

game:GetService("UserInputService").InputChanged:Connect(function(inputObj)
	if inputObj == dragInput and dragging then
		local delta = inputObj.Position - dragStart
		frame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

local function runCommand(cmd)
	if cmd == ">>help" then
		append("Commands loaded.")
	elseif cmd == "-h //" then
		highlightPlayers(false)
		append("Highlight enabled.")
	elseif cmd == "-h /h" then
		highlightPlayers(true)
		append("Highlight + health enabled.")
	elseif cmd == "-e -h--" then
		clearHighlights()
		append("Highlight disabled.")
	elseif cmd:match("%-s %-%-(%d+)&") then
		local num = tonumber(cmd:match("(%d+)"))
		humanoid.WalkSpeed = num
		append("Speed set: "..num)
	elseif cmd == "-s --re" then
		humanoid.WalkSpeed = 16
		append("Speed reset.")
	elseif cmd:match("%-j %-%-(%d+)&") then
		local num = tonumber(cmd:match("(%d+)"))
		humanoid.JumpPower = num
		append("Jump set: "..num)
	elseif cmd == "-j --re" then
		humanoid.JumpPower = 50
		append("Jump reset.")
	elseif cmd == "-airjump--/" then
		airjump = true
		append("Airjump enabled.")
	elseif cmd == "--ncL" then
		noclip = true
		append("Noclip enabled.")
	elseif cmd == "--ncL--re" then
		noclip = false
		append("Noclip disabled.")
	elseif cmd == "-Sp" then
		local ping = game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValueString()
		append("Ping: "..ping)
	elseif cmd == "-te.." then
		for _, t in pairs(game:GetService("Teams"):GetChildren()) do
			append("Team: "..t.Name)
		end
	elseif cmd == "-watch-t" then
		append(getUSTime())
	elseif cmd == "-watch-t-y" then
		append(getLocalTime())
	elseif cmd == "-cors watch/" then
		startPrediction()
		append("Prediction ON")
	elseif cmd == "-cors /" then
		stopPrediction()
		append("Prediction OFF")
	elseif cmd == "-d -on" then
		draggingEnabled = true
		append("Dragging ON")
	elseif cmd == "-d -off" then
		draggingEnabled = false
		append("Dragging OFF")
	elseif cmd == "--/clearterminal" then
		output.Text = ""
	elseif cmd == "--{}" then
		player:Kick("Error!(js, python)")
	else
		append("Unknown command.")
	end
end

input.FocusLost:Connect(function(enter)
	if enter then
		local text = input.Text:sub(#prompt() + 1)
		append(prompt() .. text)
		runCommand(text)
		input.Text = prompt()
	end
end)
