local function prompt()
	return ""
end

input.Text = prompt()

local function append(txt,isCommand)
	if isCommand then
		output.Text = output.Text .. "\n\nCOM://USER/"..player.Name.." > " .. txt
	else
		output.Text = output.Text .. "\n" .. txt
	end
end

local airjump = false
local noclip = false
local shaders = false
local dragging = true
local predicting = false

local highlights = {}
local predictionParts = {}

player.CharacterAdded:Connect(function(c)
	char = c
	humanoid = c:WaitForChild("Humanoid")
end)

UIS.JumpRequest:Connect(function()
	if airjump and humanoid then
		humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
	end
end)

RunService.Stepped:Connect(function()
	if noclip and char then
		for _,v in ipairs(char:GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide = false
			end
		end
	end
end)

local draggingNow = false
local dragInput
local dragStart
local startPos

local function update(inputObj)
	local delta = inputObj.Position - dragStart

	frame.Position = UDim2.new(
		startPos.X.Scale,
		startPos.X.Offset + delta.X,
		startPos.Y.Scale,
		startPos.Y.Offset + delta.Y
	)
end

topbar.InputBegan:Connect(function(inputObj)
	if not dragging then
		return
	end

	if inputObj.UserInputType == Enum.UserInputType.MouseButton1 then
		draggingNow = true
		dragStart = inputObj.Position
		startPos = frame.Position

		inputObj.Changed:Connect(function()
			if inputObj.UserInputState == Enum.UserInputState.End then
				draggingNow = false
			end
		end)
	end
end)

topbar.InputChanged:Connect(function(inputObj)
	if inputObj.UserInputType == Enum.UserInputType.MouseMovement then
		dragInput = inputObj
	end
end)

UIS.InputChanged:Connect(function(inputObj)
	if inputObj == dragInput and draggingNow then
		update(inputObj)
	end
end)

local function clearHighlights()
	for _,v in ipairs(highlights) do
		if v then
			v:Destroy()
		end
	end

	highlights = {}
end

local function highlightPlayers(showHealth)
	clearHighlights()

	for _,plr in ipairs(Players:GetPlayers()) do
		if plr ~= player and plr.Character then

			local h = Instance.new("Highlight")
			h.FillColor = Color3.fromRGB(255,0,0)
			h.OutlineColor = Color3.fromRGB(255,255,255)
			h.Parent = plr.Character

			table.insert(highlights,h)

			if showHealth then
				local bill = Instance.new("BillboardGui")
				bill.Size = UDim2.new(0,100,0,40)
				bill.AlwaysOnTop = true
				bill.Parent = plr.Character:FindFirstChild("Head")

				local txt = Instance.new("TextLabel")
				txt.Parent = bill
				txt.Size = UDim2.new(1,0,1,0)
				txt.BackgroundTransparency = 1
				txt.Font = Enum.Font.Code
				txt.TextColor3 = Color3.fromRGB(0,255,0)
				txt.Text = "HP: "..math.floor(plr.Character.Humanoid.Health)

				table.insert(highlights,bill)
			end
		end
	end
end

local function predictionOn()
	predicting = true

	task.spawn(function()
		while predicting do
			for _,plr in ipairs(Players:GetPlayers()) do
				if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then

					local root = plr.Character.HumanoidRootPart
					local pos = root.Position + root.Velocity

					local part = Instance.new("Part")
					part.Anchored = true
					part.CanCollide = false
					part.Size = Vector3.new(1,1,1)
					part.Shape = Enum.PartType.Ball
					part.Material = Enum.Material.Neon
					part.Color = Color3.fromRGB(0,255,0)
					part.Position = pos
					part.Parent = workspace

					table.insert(predictionParts,part)

					task.delay(0.5,function()
						if part then
							part:Destroy()
						end
					end)
				end
			end

			task.wait(0.3)
		end
	end)
end

local function predictionOff()
	predicting = false

	for _,v in ipairs(predictionParts) do
		if v then
			v:Destroy()
		end
	end

	predictionParts = {}
end

local bloom = Instance.new("BloomEffect")
local colorCorrection = Instance.new("ColorCorrectionEffect")

local function shadersOn()
	shaders = true

	bloom.Intensity = 1
	bloom.Size = 24
	bloom.Parent = Lighting

	colorCorrection.Contrast = 0.15
	colorCorrection.Saturation = 0.25
	colorCorrection.Parent = Lighting

	append("Shaders enabled.")
end

local function shadersOff()
	shaders = false

	bloom.Parent = nil
	colorCorrection.Parent = nil

	append("Shaders disabled.")
end

local function antiLag()
	for _,v in ipairs(workspace:GetDescendants()) do

		if v:IsA("ParticleEmitter")
		or v:IsA("Trail")
		or v:IsA("Smoke")
		or v:IsA("Fire")
		or v:IsA("Sparkles") then

			v.Enabled = false
		end

		if v:IsA("BasePart") then
			v.Material = Enum.Material.Plastic
			v.Reflectance = 0
		end
	end

	Lighting.GlobalShadows = false
	Lighting.FogEnd = 100000

	append("Anti-lag optimization complete.")
end

