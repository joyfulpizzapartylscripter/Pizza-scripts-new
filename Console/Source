local function showCommands()
	append("")
	append("========== COMMAND LIST ==========")

	for cmd,desc in pairs(commands) do
		append(cmd .. " -> " .. desc)
	end

	append("==================================")
end

local function runCommand(cmd)

	local lower = string.lower(cmd)

	if lower == "?" or lower == "cmds" then
		showCommands()

	elseif lower == "clear" then
		output.Text = ""

	elseif lower == "exit" then
		gui:Destroy()

	elseif lower:match("^speed (%d+)$") then
		local n = tonumber(lower:match("%d+"))
		humanoid.WalkSpeed = n
		append("WalkSpeed set to "..n)

	elseif lower == "speed reset" then
		humanoid.WalkSpeed = 16
		append("WalkSpeed reset.")

	elseif lower:match("^jump (%d+)$") then
		local n = tonumber(lower:match("%d+"))
		humanoid.JumpPower = n
		append("JumpPower set to "..n)

	elseif lower == "jump reset" then
		humanoid.JumpPower = 50
		append("JumpPower reset.")

	elseif lower == "airjump on" then
		airjump = true
		append("Airjump enabled.")

	elseif lower == "airjump off" then
		airjump = false
		append("Airjump disabled.")

	elseif lower == "noclip on" then
		noclip = true
		append("Noclip enabled.")

	elseif lower == "noclip off" then
		noclip = false
		append("Noclip disabled.")

	elseif lower == "highlight on" then
		highlightPlayers(false)
		append("Highlight enabled.")

	elseif lower == "highlight health" then
		highlightPlayers(true)
		append("Highlight health enabled.")

	elseif lower == "highlight off" then
		clearHighlights()
		append("Highlights cleared.")

	elseif lower == "ping" then
		local ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValueString()
		append("Ping: "..ping)

	elseif lower == "fps" then
		append("FPS estimate: "..math.floor(1 / RunService.RenderStepped:Wait()))

	elseif lower == "time" then
		append(os.date("%X"))

	elseif lower == "teams" then
		for _,t in ipairs(game:GetService("Teams"):GetChildren()) do
			append("Team: "..t.Name)
		end

	elseif lower == "players" then
		for _,p in ipairs(Players:GetPlayers()) do
			append("Player: "..p.Name)
		end

	elseif lower == "predict on" then
		predictionOn()
		append("Prediction enabled.")

	elseif lower == "predict off" then
		predictionOff()
		append("Prediction disabled.")

	elseif lower == "drag on" then
		dragging = true
		append("Dragging enabled.")

	elseif lower == "drag off" then
		dragging = false
		append("Dragging disabled.")

	elseif lower == "reset" then
		char:BreakJoints()

	elseif lower == "sit" then
		humanoid.Sit = true

	elseif lower == "jumpnow" then
		humanoid:ChangeState(Enum.HumanoidStateType.Jumping)

	elseif lower == "rejoin" then
		game:GetService("TeleportService"):Teleport(game.PlaceId,player)

	elseif lower:match("^zoom (%d+)$") then
		local n = tonumber(lower:match("%d+"))
		player.CameraMaxZoomDistance = n
		append("Zoom set to "..n)

	elseif lower:match("^fov (%d+)$") then
		local n = tonumber(lower:match("%d+"))
		workspace.CurrentCamera.FieldOfView = n
		append("FOV set to "..n)

	elseif lower == "shader on" then
		shadersOn()

	elseif lower == "shader off" then
		shadersOff()

	elseif lower == "--antilag" then
		antiLag()

	elseif lower == "day" then
		Lighting.ClockTime = 14
		append("Daytime set.")

	elseif lower == "night" then
		Lighting.ClockTime = 0
		append("Nighttime set.")

	elseif lower:match("^gravity (%d+)$") then
		local n = tonumber(lower:match("%d+"))
		workspace.Gravity = n
		append("Gravity set to "..n)

	else
		append("'"..cmd.."' is not recognized as a command.")
	end
end

input.FocusLost:Connect(function(enterPressed)

	if not enterPressed then
		return
	end

	local txt = input.Text

	append(txt,true)

	runCommand(txt)

	input.Text = ""
end)

append("")
append("Terminal initialized successfully.")
